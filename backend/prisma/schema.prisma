// server/prisma/schema.prisma

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           Int           @id @default(autoincrement())
  firstName    String
  lastName     String
  email        String        @unique
  username     String        @unique
  passwordHash String
  createdAt    DateTime      @default(now())
  

  conversationsAsA Conversation[] @relation("ConversationUserA")
  conversationsAsB Conversation[] @relation("ConversationUserB")
  // Relacje: Użytkownik może napisać wiele wiadomości
  messages     Message[]
}

model Conversation {
  id          Int       @id @default(autoincrement())
  createdAt   DateTime  @default(now())

  // the two participants
  userAId     Int
  userA       User      @relation("ConversationUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userBId     Int
  userB       User      @relation("ConversationUserB", fields: [userBId], references: [id], onDelete: Cascade)

  messages    Message[]

  @@unique([userAId, userBId]) // one conversation per pair
}

model Message {
  id             Int          @id @default(autoincrement())
  content        String
  createdAt      DateTime     @default(now())

  authorId       Int
  author         User         @relation(fields: [authorId], references: [id], onDelete: Cascade)

  conversationId Int
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}