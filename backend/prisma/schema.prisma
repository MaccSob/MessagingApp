// server/prisma/schema.prisma

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           Int           @id @default(autoincrement())
  firstName    String
  lastName     String
  email        String        @unique
  username     String        @unique
  passwordHash String
  createdAt    DateTime      @default(now())
  
  // Relacje: Użytkownik może napisać wiele wiadomości
  messages     Message[]
}

model Channel {
  id          Int           @id @default(autoincrement())
  name        String
  description String?
  createdAt   DateTime      @default(now())
  
  // Relacje: Kanał ma w sobie wiele wiadomości
  messages    Message[]
}

model Message {
  id        Int      @id @default(autoincrement())
  content   String
  createdAt DateTime @default(now())

  // Relacja do Użytkownika (Autora)
  authorId  Int
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  // Relacja do Kanału
  channelId Int
  channel   Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
}
